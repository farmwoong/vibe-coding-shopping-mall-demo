PORT=5000

# MongoDB: MONGODB_ATLAS_URL이 있으면 우선 사용, 없으면 MONGODB_URI 또는 로컬 주소 사용
# MONGODB_ATLAS_URL=mongodb+srv://user:pass@cluster.mongodb.net/dbname
# MONGODB_URI=mongodb://localhost:27017/shopping-mall
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# 포트원 결제 검증 (REST API 키 - 포트원 대시보드에서 발급)
PORTONE_REST_API_KEY=your-portone-rest-api-key
REST_API_SECRET=your-portone-rest-api-secret

# 테스트 결제 시 REST API에 imp_uid가 없을 수 있음. 개발 시 true로 설정하면 검증 생략
# SKIP_PAYMENT_VERIFICATION=true
